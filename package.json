{
  "name": "playground",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter './games/*' build",
    "build:sdk": "pnpm --filter @playground/sdk build",
    "dev": "pnpm -r --parallel --filter './games/*' dev",
    "deploy": "node scripts/deploy.js"
  }
}
